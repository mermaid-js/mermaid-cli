{
  "name": "@mermaid-js/mermaid-cli",
  "version": "11.15.0",
  "description": "Command-line interface for mermaid",
  "license": "MIT",
  "repository": "git@github.com:mermaid-js/mermaid-cli.git",
  "type": "module",
  "author": "Tyler Long <tyler4long@gmail.com>",
  "bin": {
    "mmdc": "./src/cli.js"
  },
  "engines": {
    "node": "^18.19 || >=20.0"
  },
  "exports": {
    ".": {
      "types": "./dist-types/src/index.d.ts",
      "default": "./src/index.js"
    }
  },
  "types": "./dist-types/src/index.d.ts",
  "scripts": {
    "prepare": "tsc && vite build",
    "prepack": "tsc && vite build",
    "test": "cross-env-shell NODE_OPTIONS=\"$NODE_OPTIONS --experimental-vm-modules\" npx jest",
    "test:cli": "bash run-tests.sh test-positive",
    "version": "node scripts/version.js",
    "lint": "standard",
    "lint-fix": "standard --fix"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.0.0 || ^7.0.1",
    "@mermaid-js/layout-elk": "^0.1.5 || ^0.2.0",
    "@mermaid-js/mermaid-zenuml": "^0.2.0",
    "chalk": "^5.0.1",
    "commander": "^13.1.0",
    "import-meta-resolve": "^4.1.0",
    "katex": "^0.16.25",
    "mermaid": "^11.14.0",
    "p-limit": "^6.2.0"
  },
  "optionalDependencies": {
    "@mermaid-js/layout-tidy-tree": "^0.2.1"
  },
  "peerDependencies": {
    "puppeteer": "^23 || ^24"
  },
  "devDependencies": {
    "@tsconfig/node18": "^18.2.4",
    "@types/node": "~18.19.31",
    "cross-env": "^7.0.3",
    "jest": "^30.0.5",
    "puppeteer": "^24.0.0",
    "standard": "^17.0.0",
    "typescript": "^6.0.3",
    "vite": "^6.0.2",
    "yarn-upgrade-all": "^0.8.1"
  },
  "files": [
    "src/",
    "dist/",
    "dist-types/"
  ],
  "jest": {
    "moduleNameMapper": {
      "#(.*)": "<rootDir>/node_modules/$1"
    }
  },
  "standard": {
    "ignore": [
      "/dist/",
      "/dist-types/"
    ]
  },
  "packageManager": "npm@10.8.1"
}
